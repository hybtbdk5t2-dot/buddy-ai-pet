# =============================================================================
# AIプロバイダー設定
# AIは「会話文」と「日記本文」の生成にのみ使われます。
# レベル・経験値・親密度・成長・記憶・セーブなどはすべてローカルで処理され、
# APIキーが無くてもデモ（ルールベース）で一通り動作します。
# =============================================================================

# 使用するプロバイダーを固定したい場合に指定:
#   openai | gemini | claude | openrouter | local
# 未指定 または auto のときは、下で設定済みのものを自動選択します。
# demo にすると常にローカル応答（AIを呼ばない）。
AI_PROVIDER=auto

# 多段フォールバックの試行順（設定するとAI_PROVIDERより優先）。
# 例: 先頭から順に試し、失敗したら次へ。全滅したらローカル定型応答。
# AI_PROVIDER_ORDER=gemini,openrouter,local

# 会話内容に応じたモデル自動切替（任意）。未設定なら各プロバイダー既定モデル。
#   軽い会話 -> AI_LIGHT_MODEL / 深い相談・日記 -> AI_HEAVY_MODEL
# AI_LIGHT_MODEL=
# AI_HEAVY_MODEL=

# AI利用予算（0 または未設定で無制限）。ユーザー単位・1日あたり。
# AI_DAILY_CALL_LIMIT=0
# AI_DAILY_TOKEN_LIMIT=0

# プロンプトのA/Bバリアント（prompts/registry.json の "{id}__B" を使う等）
# AI_PROMPT_VARIANT=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # 互換エンドポイントを使う場合のみ

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- OpenRouter（1つのキーで多数のLLM）---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_SITE_URL=          # 任意（OpenRouterのランキング用ヘッダ）
# OPENROUTER_APP_NAME=Buddy     # 任意

# --- ローカルLLM（Ollama / LM Studio / llama.cpp / vLLM 等。OpenAI互換API）---
# 例: Ollama -> http://localhost:11434/v1  /  モデル: llama3.1, qwen2.5, gemma2 など
LOCAL_AI_BASE_URL=
LOCAL_AI_MODEL=llama3.1
# LOCAL_AI_API_KEY=             # 認証が必要なサーバーのみ
